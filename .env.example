# =========================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# Server Port (Default: 5000)
PORT=5000

# Required: MongoDB Database URI (MongoDB Atlas or Local MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/faheem_portfolio?retryWrites=true&w=majority

# Required: Secret key used for signing administrative JWT session tokens
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Optional: Administrative Seeding Credentials (hashed automatically upon first initialization)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# Optional: Cloudinary Storage Credentials (for persistent CMS image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_URL=your_cloudinary_url

# =========================================================================
# Frontend Configurations
# =========================================================================
VITE_API_URL=http://localhost:5000
